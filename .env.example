# ─────────────────────────────────────────────
# NEXUS — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=

# ── Cloudflare R2 (Storage) ───────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nexus-assets
R2_PUBLIC_URL=

# ── Claude API ────────────────────────────────
ANTHROPIC_API_KEY=

# ── OpenAI (Embeddings) ───────────────────────
OPENAI_API_KEY=

# ── Cohere (Multilingual Embeddings) ─────────
COHERE_API_KEY=
VECTOR_NAMESPACE_PREFIX=nexus_kb_

# ── 3D Reconstruction ─────────────────────────
LUMA_AI_API_KEY=
LUMA_AI_API_URL=https://api.lumalabs.ai

# ── Language AI ───────────────────────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_TRANSLATOR_KEY=
META_SEAMLESS_API_URL=       # if self-hosting SeamlessM4T

# ── Group Audio (WebSocket) ───────────────────
AUDIO_SYNC_WS_PATH=/audio
AUDIO_SYNC_MAX_LISTENERS=200

# ── Security Intelligence ─────────────────────
SECURITY_REPORT_EXPIRY_HOURS=72
SECURITY_VALIDATION_THRESHOLD=3
SAFETY_COMPANION_MAX_HOURS=8

# ── NFC / Offline ─────────────────────────────
NFC_OFFLINE_QUEUE_MAX=50

# ── PDF Export (Gotenberg) ────────────────────
GOTENBERG_URL=

# ── Quiz ──────────────────────────────────────
QUIZ_SHORT_ANSWER_CONFIDENCE_THRESHOLD=0.7

# ── App Config ────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:8081
LOG_LEVEL=debug
